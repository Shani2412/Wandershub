<!DOCTYPE html>
<html>
<head>
<title>🏡 WandersHub — Login</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Poppins', sans-serif;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* bright background image — no overlay */
.bg {
  position: fixed;
  inset: 0;
  background: url("https://wallpapercave.com/wp/MwgLhZY.jpg") no-repeat center center;
  background-size: cover;
  filter: brightness(1.08) saturate(1.15) contrast(1.05);
  z-index: 0;
}

/* glass card */
.login-container {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-radius: 24px;
  padding: 44px 40px 36px;
  width: 380px;
  text-align: center;
  box-shadow:
    0 24px 60px rgba(0, 0, 0, 0.45),
    inset 0 1px 0 rgba(255, 255, 255, 0.4),
    inset 0 -1px 0 rgba(255,255,255,0.1);
  border: 1px solid rgba(255, 255, 255, 0.3);
  animation: fadeUp 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* brand */
.brand-icon {
  font-size: 40px;
  display: block;
  margin-bottom: 6px;
  animation: fadeUp 0.6s 0.1s ease both;
}

.brand-name {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5px;
  text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  animation: fadeUp 0.6s 0.15s ease both;
}

.brand-name span {
  color: #93c5fd;
}

.brand-tagline {
  font-size: 12.5px;
  color: rgba(255,255,255,0.65);
  font-weight: 300;
  margin-top: 5px;
  margin-bottom: 28px;
  animation: fadeUp 0.6s 0.2s ease both;
}

/* divider */
.divider {
  height: 1px;
  background: rgba(255,255,255,0.2);
  margin-bottom: 26px;
}

/* error box */
.login-error-box {
  background: rgba(239, 68, 68, 0.18);
  border: 1px solid rgba(239, 68, 68, 0.45);
  color: #fecaca;
  padding: 11px 14px;
  border-radius: 12px;
  margin-bottom: 18px;
  font-size: 13px;
  text-align: left;
  display: flex;
  gap: 8px;
  align-items: flex-start;
}

/* fields */
.field {
  margin-bottom: 14px;
  text-align: left;
  animation: fadeUp 0.6s ease both;
}

.field:nth-child(1) { animation-delay: 0.25s; }
.field:nth-child(2) { animation-delay: 0.32s; }

.field label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 7px;
  padding-left: 2px;
}

.field input {
  width: 100%;
  padding: 13px 16px;
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 12px;
  outline: none;
  font-size: 14px;
  font-family: 'Poppins', sans-serif;
  background: rgba(255,255,255,0.15);
  color: #fff;
  transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
}

.field input::placeholder {
  color: rgba(255,255,255,0.4);
}

.field input:focus {
  border-color: rgba(147, 197, 253, 0.8);
  background: rgba(255,255,255,0.22);
  box-shadow: 0 0 0 3px rgba(147,197,253,0.2);
}

/* forgot */
.forgot-link {
  display: block;
  text-align: right;
  font-size: 12px;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  margin: -4px 0 22px;
  transition: color 0.2s;
  animation: fadeUp 0.6s 0.38s ease both;
}

.forgot-link:hover { color: #93c5fd; }

/* button */
.btn-login {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #6a11cb, #2575fc);
  color: #fff;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  font-weight: 600;
  font-size: 15px;
  font-family: 'Poppins', sans-serif;
  letter-spacing: 0.04em;
  transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
  box-shadow: 0 4px 20px rgba(37, 117, 252, 0.45);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.6s 0.42s ease both;
}

.btn-login::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.18), transparent 60%);
}

.btn-login:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(37, 117, 252, 0.6);
  filter: brightness(1.1);
}

.btn-login:active { transform: translateY(0); }

/* signup */
.signup-text {
  margin-top: 22px;
  color: rgba(255,255,255,0.55);
  font-size: 13px;
  font-weight: 300;
  animation: fadeUp 0.6s 0.5s ease both;
}

.signup-text a {
  color: #93c5fd;
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s;
}

.signup-text a:hover {
  color: #bfdbfe;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* autofill fix */
input:-webkit-autofill,
input:-webkit-autofill:focus {
  -webkit-text-fill-color: #fff;
  -webkit-box-shadow: 0 0 0px 1000px rgba(255,255,255,0.15) inset;
  transition: background-color 5000s;
}
</style>
</head>
<body>

<div class="bg"></div>

<div class="login-container">

  <span class="brand-icon">🏡</span>
  <div class="brand-name">Wanders<span>Hub</span></div>
  <p class="brand-tagline">Buy &amp; Sell — Anywhere, Anytime</p>

  <div class="divider"></div>

  <% if (error) { %>
  <div class="login-error-box">
    ⚠&nbsp;<div><strong>Login Failed</strong><br><%= error %></div>
  </div>
  <% } %>

  <form action="/login" method="POST">
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" placeholder="you@example.com" required>
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required>
    </div>

    <a href="/forgot" class="forgot-link">Forgot password?</a>

    <button type="submit" class="btn-login">Login</button>
  </form>

  <p class="signup-text">
    Don't have an account? <a href="/signup">Sign up</a>
  </p>

</div>

</body>
</html>