<% layout('layouts/admin') %>
<% pageTitle = 'Users' %>
<% page = 'users' %>

<div class="wh-page-header">
  <h1 class="wh-page-title">Users</h1>
  <p class="wh-page-sub">Manage all registered members of WandersHub.</p>
</div>

<div class="wh-card">
  <% if (users && users.length > 0) { %>
  <div class="wh-table-wrap">
    <table class="wh-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Username</th>
          <th class="wh-hide-mobile">Email</th>
          <th style="text-align:center;">Role</th>
          <th>Joined</th>
          <th style="text-align:center;">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user, i) => { %>
        <tr>
          <td class="wh-table__index"><%= i + 1 %></td>
          <td>
            <div class="wh-user-cell">
              <span class="wh-avatar wh-avatar--sm"><i class="bi bi-person-fill"></i></span>
              <span class="wh-user-cell__name"><%= user.username %></span>
            </div>
          </td>
          <td class="wh-table__muted wh-hide-mobile"><%= user.email %></td>
          <td>
            <div class="wh-cell-center">
              <% if (user.role === 'admin') { %>
                <span class="wh-badge wh-badge--green"><i class="bi bi-shield-fill"></i> Admin</span>
              <% } else { %>
                <span class="wh-badge wh-badge--grey"><i class="bi bi-person-fill"></i> User</span>
              <% } %>
            </div>
          </td>
          <td class="wh-table__muted">
            <%
              let joinDate = 'N/A';
              try {
                const d = user.createdAt ? new Date(user.createdAt) : new Date(parseInt(user._id.toString().substring(0,8), 16) * 1000);
                if (!isNaN(d.getTime())) joinDate = d.toLocaleDateString('en-IN', {year:'numeric', month:'short', day:'numeric'});
              } catch(e) {}
            %>
            <%= joinDate %>
          </td>
          <td>
            <div class="wh-cell-center">
              <form action="/admin/users/<%= user._id %>?_method=DELETE" method="POST">
                <button class="wh-btn wh-btn--danger"><i class="bi bi-trash3-fill"></i> Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="wh-empty">
    <i class="bi bi-people wh-empty__icon"></i>
    <h3 class="wh-empty__title">No Users Found</h3>
    <p class="wh-empty__sub">No users have registered yet.</p>
  </div>
  <% } %>
</div>
