<% layout('layouts/admin') %>
<% pageTitle = 'Dashboard' %>
<% page = 'dashboard' %>

<div class="wh-page-header">
  <h1 class="wh-page-title">Overview</h1>
  <p class="wh-page-sub">Welcome back, Admin. Click any card to manage.</p>
</div>

<!-- Stat Cards — each is a clickable link -->
<div class="row g-4">
  <div class="col-12 col-md-4">
    <a href="/admin/users" class="wh-stat-card wh-stat-card--blue wh-stat-card--link">
      <div class="wh-stat-card__icon"><i class="bi bi-people-fill"></i></div>
      <div class="wh-stat-card__body">
        <p class="wh-stat-card__label">Total Users</p>
        <h2 class="wh-stat-card__value"><%= totalUsers %></h2>
        <p class="wh-stat-card__cta">Manage Users <i class="bi bi-arrow-right-short"></i></p>
      </div>
      <div class="wh-stat-card__bg-icon"><i class="bi bi-people-fill"></i></div>
    </a>
  </div>

  <div class="col-12 col-md-4">
    <a href="/admin/listings" class="wh-stat-card wh-stat-card--purple wh-stat-card--link">
      <div class="wh-stat-card__icon"><i class="bi bi-shop-window"></i></div>
      <div class="wh-stat-card__body">
        <p class="wh-stat-card__label">Total Listings</p>
        <h2 class="wh-stat-card__value"><%= totalListings %></h2>
        <p class="wh-stat-card__cta">Manage Listings <i class="bi bi-arrow-right-short"></i></p>
      </div>
      <div class="wh-stat-card__bg-icon"><i class="bi bi-shop-window"></i></div>
    </a>
  </div>

  <div class="col-12 col-md-4">
    <a href="/admin/reviews" class="wh-stat-card wh-stat-card--teal wh-stat-card--link">
      <div class="wh-stat-card__icon"><i class="bi bi-chat-square-dots-fill"></i></div>
      <div class="wh-stat-card__body">
        <p class="wh-stat-card__label">Total Reviews</p>
        <h2 class="wh-stat-card__value"><%= totalReviews %></h2>
        <p class="wh-stat-card__cta">Manage Reviews <i class="bi bi-arrow-right-short"></i></p>
      </div>
      <div class="wh-stat-card__bg-icon"><i class="bi bi-chat-square-dots-fill"></i></div>
    </a>
  </div>
</div>
