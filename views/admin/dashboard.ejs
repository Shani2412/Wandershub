<% layout('layouts/admin') %>
<% pageTitle = 'Dashboard' %>
<% page = 'dashboard' %>

<div class="wh-page-header">
  <h1 class="wh-page-title">Overview</h1>
  <p class="wh-page-sub">Welcome back, Admin.</p>
</div>

<div class="wh-cards-row">

  <!-- Users Card -->
  <div class="wh-cards-col">
    <a href="/admin/users" class="wh-scard">
      <div class="wh-scard__top">
        <div class="wh-scard__brand">
          <i class="bi bi-people-fill"></i>
          <span>WandersHub</span>
        </div>
        <h2 class="wh-scard__title">Users</h2>
        <p class="wh-scard__count"><%= totalUsers %> registered</p>
      </div>
      <hr class="wh-scard__divider"/>
      <ul class="wh-scard__list">
        <li><i class="bi bi-dot"></i> View all registered users</li>
        <li><i class="bi bi-dot"></i> Manage admin roles</li>
        <li><i class="bi bi-dot"></i> Delete accounts</li>
      </ul>
      <div class="wh-scard__footer">
        <button class="wh-scard__btn">Manage Users</button>
      </div>
    </a>
  </div>

  <!-- Listings Card — featured -->
  <div class="wh-cards-col">
    <a href="/admin/listings" class="wh-scard wh-scard--featured">
      <div class="wh-scard__ribbon">Most Active</div>
      <div class="wh-scard__top">
        <div class="wh-scard__brand">
          <i class="bi bi-shop-window"></i>
          <span>WandersHub</span>
        </div>
        <h2 class="wh-scard__title">Listings</h2>
        <p class="wh-scard__count"><%= totalListings %> properties</p>
        <p class="wh-scard__sub">Active &amp; sold listings</p>
      </div>
      <hr class="wh-scard__divider"/>
      <ul class="wh-scard__list">
        <li><i class="bi bi-dot"></i> View all properties</li>
        <li><i class="bi bi-dot"></i> Track active &amp; sold status</li>
        <li><i class="bi bi-dot"></i> Remove any listing</li>
        <li><i class="bi bi-dot"></i> Monitor prices</li>
      </ul>
      <div class="wh-scard__footer">
        <button class="wh-scard__btn wh-scard__btn--featured">Manage Listings</button>
      </div>
    </a>
  </div>

  <!-- Reviews Card -->
  <div class="wh-cards-col">
    <a href="/admin/reviews" class="wh-scard">
      <div class="wh-scard__top">
        <div class="wh-scard__brand">
          <i class="bi bi-star-fill"></i>
          <span>WandersHub</span>
        </div>
        <h2 class="wh-scard__title">Reviews</h2>
        <p class="wh-scard__count"><%= totalReviews %> submitted</p>
      </div>
      <hr class="wh-scard__divider"/>
      <ul class="wh-scard__list">
        <li><i class="bi bi-dot"></i> View all user reviews</li>
        <li><i class="bi bi-dot"></i> Check star ratings</li>
        <li><i class="bi bi-dot"></i> Delete reviews</li>
      </ul>
      <div class="wh-scard__footer">
        <button class="wh-scard__btn">Manage Reviews</button>
      </div>
    </a>
  </div>

</div>
